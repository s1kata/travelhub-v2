# Настройки проекта (скопируйте в .env и заполните)
# Источник: TravelHubNew (.env.example)

# ============ Яндекс.Карты (виджет отзывов на главной и др.) ============
# Числовой ID организации: откройте карточку компании на yandex.ru/maps — в URL или в коде виджета отзывов
# YANDEX_REVIEWS_ORG_ID=

# ============ Яндекс.Метрика (счётчик на сайте + reachGoal в JS) ============
# Числовой ID счётчика. Если не задан — в коде используется 109291068.
# YANDEX_METRIKA_ID=109291068

# ============ Firebase / Firestore (кэш поиска туров) ============
FIREBASE_PROJECT_ID=
# Путь к JSON сервисного аккаунта (или оставьте пустым — тогда config/firebase-service-account.json или backend/config/firebase-service-account.json)
FIREBASE_SERVICE_ACCOUNT=
# Вебхук Т‑Кассы (payment-webhook) помечает оплату в Firestore (bookings.paymentStatus) — нужны те же переменные, что и для кэша туров

# ============ Tourvisor API ============
TOURVISOR_TOKEN=
# ID модуля из кабинета Tourvisor для init.js (виджеты на сайте). Если пусто — подставляется значение по умолчанию в коде.
# TOURVISOR_WIDGET_ID=9974456

# Опционально: отдельные токены на поисковик (main=главная, promo=акции, countries=страны). Если не заданы — используется TOURVISOR_TOKEN.
# TOURVISOR_TOKEN_MAIN=
# TOURVISOR_TOKEN_PROMO=
# TOURVISOR_TOKEN_COUNTRIES=
TOURVISOR_API_URL=https://api.tourvisor.ru/search/api/v1
# TTL кэша (часы). СВЕЖЕСТЬ > СКОРОСТЬ: поиск 14 дней (336 ч), при промахе — живой поиск
TOURVISOR_CACHE_TTL_HOURS=168
TOURVISOR_ALL_TOURS_CACHE_TTL_HOURS=336
TOURVISOR_SEARCH_CACHE_TTL_HOURS=336
# Короткий кэш «живых» запросов (секунды): /tours/{id} и /tours/{id}/flights (снижает burst-нагрузку, почти не влияя на свежесть)
# 0 = отключить
TOURVISOR_TOUR_LIVE_CACHE_TTL_SECONDS=60
# Серверный кэш байтов для прокси картинок static.tourvisor.ru (дни)
TOURVISOR_IMAGE_CACHE_TTL_DAYS=30
# При 1 — использовать статические fallback при ошибках API
TOURVISOR_USE_FALLBACKS=0
# Папка кэша (если не задано — data/tourvisor_cache)
# TOURVISOR_CACHE_DIR=
# TTL кэша акционных туров (часы): 24 по умолчанию. Обновление 12:00 и 00:05 МСК.
# TOURVISOR_PROMO_CACHE_TTL_HOURS=24
# Origin сайта (без /frontend/...): для cron и HTTP к tourvisor-proxy. Пример: https://travelhub63.ru
# Главная у вас может быть https://travelhub63.ru/frontend/index.php — в SITE_URL всё равно только хост и схема (или корень без /frontend).
# SITE_URL=https://travelhub63.ru
# Публичный путь прокси по умолчанию: /frontend/api/tourvisor-proxy.php (если у вас только /backend/ — задайте backend/api/tourvisor-proxy.php)
# TOURVISOR_PROXY_RELATIVE_PATH=frontend/api/tourvisor-proxy.php
# Либо полный URL прокси:
# TOURVISOR_PROXY_URL=https://travelhub63.ru/frontend/api/tourvisor-proxy.php

# Страница /frontend/window/debug.php: 0 = 404 для всех; 1 = можно открыть (плюс вход под admin)
DEBUG_PAGE_ENABLED=0

# ============ U-ON CRM (бронирования) ============
# Ключ API: Настройки → Интеграции → API в личном кабинете U-ON (https://*.u-on.ru)
# Без ключа заявки сохраняются только в БД сайта, в CRM не отправляются.
# Подхватываются оба файла: backend/.env и этот файл в корне (если оба есть — значения из корня перекрывают backend).
UON_API_KEY=
# Источник заявки (одно значение для всех заявок с сайта)
UON_SOURCE=Сайт
# ID статусов заявки в U-ON (см. метод /status в API): «Бронирование без оплаты» и «Бронирование с оплатой»
UON_STATUS_WITHOUT_PAYMENT=
UON_STATUS_WITH_PAYMENT=

# ============ Способы оплаты (ключи для редиректа на оплату) ============
# Альфа-банк (интернет-эквайринг)
# Логин и пароль выдаются банком при подключении. См. backend/payment/ALFABANK_README.md
PAYMENT_ALFA_MERCHANT=
PAYMENT_ALFA_SECRET=
# 1 = тестовый режим (без реальных списаний), 0 = боевой
PAYMENT_ALFA_TEST=1
# Т-Банк (T-Bank / Tinkoff)
PAYMENT_TBANK_TERMINAL_KEY=
PAYMENT_TBANK_SECRET_KEY=

# Tinkoff T-Kassa (API для мобильного приложения: /api/create-payment, /api/payment-webhook)
# Ключ и пароль терминала — в личном кабинете Т-Бизнес (интернет-эквайринг)
TINKOFF_TERMINAL_KEY=
TINKOFF_PASSWORD=
# Секрет JWT из api/auth-mobile.config.php (jwt_secret) — только для серверного моста оплаты сайта
MOBILE_JWT_SECRET=
# MOBILE_JWT_ISSUER=travelhub-auth
# Базовый URL сайта для SuccessURL, FailURL, NotificationURL (например https://travelhub63.ru)
APP_URL=https://travelhub63.ru
API_URL=https://travelhub63.ru
# СберПэй (Сбербанк)
PAYMENT_SBERPAY_LOGIN=
PAYMENT_SBERPAY_PASSWORD=

# ============ Почта (сброс пароля, Space Web) ============
# URL сайта для ссылки в письме
# SITE_URL=https://travelhub63.ru
# Адрес отправителя (должен совпадать с ящиком в панели Space Web)
# MAIL_FROM=noreply@travelhub63.ru
# SMTP (обязательно для Space Web — mail() часто не работает):
# MAIL_SMTP_HOST=smtp.spaceweb.ru
# MAIL_SMTP_PORT=465
# MAIL_SMTP_USER=noreply@travelhub63.ru
# MAIL_SMTP_PASS=пароль_от_ящика
# MAIL_SMTP_SSL=1

# ============ Приложение ============
APP_DEBUG=0

# ============ Синхронизация promo_tours (cron: php backend/promo_tours_sync/fetch_tours.php) ============
# Основной источник: TourVisor через прокси (по умолчанию SITE_URL + /frontend/api/tourvisor-proxy.php)
# PROMO_TOURS_SYNC_DEPARTURE_ID=1
# Пауза между запросами по странам, сек (как в promo_tours_refresh)
# PROMO_TOURS_SYNC_DELAY_SEC=2
# 1 — передать live=1 в прокси (живой запрос; по умолчанию только кэш, как на фронте)
# PROMO_TOURS_SYNC_LIVE=0
# Список countryId через запятую (если не задан — берётся backend/config/country_promo_tourvisor_map.php)
# PROMO_TOURS_SYNC_COUNTRY_IDS=
# Дополнительно подмешать JSON (legacy), опционально:
# PROMO_TOURS_JSON_URL=
# PROMO_TOURS_HTTP_TIMEOUT=120

# ============ YML-фид для Яндекс.Бизнеса (услуги + акционные туры) ============
# Публичный URL фида (не менять без настройки в кабинете Яндекса): /export/services_yml.php
# Пример полного URL: https://travelhub63.ru/export/services_yml.php
# SITE_URL — origin без /frontend (для абсолютных ссылок в офферах и картинках)
# YML_SHOP_NAME=Travel Hub
# YML_SHOP_COMPANY=Travel Hub
# TTL при запросе фида (секунды): пересборка services.yml не чаще чем раз в N секунд
# YML_TTL_SECONDS=600
# Город вылета для поиска акций в фиде (как в Tourvisor). Подпись в ссылке tour-detail (departure_city)
# YML_FEED_DEPARTURE_ID=12
# YML_FEED_DEPARTURE_NAME=Самара
# Fallback на странице Акции, если открыли countryId без departureId (должен совпадать с Tourvisor)
# PROMO_DEFAULT_DEPARTURE_ID=12
# PROMO_DEFAULT_DEPARTURE_NAME=Самара
# Макс. офферов на страну при синке и верхний предел строк в YML
# YML_FEED_MAX_PER_COUNTRY=18
# YML_FEED_MAX_OFFERS_TOTAL=500
# Пауза между странами (сек) — больше = мягче для API Tourvisor
# YML_FEED_COUNTRY_DELAY_SEC=4
# Таймаут HTTP к прокси (сек)
# YML_FEED_HTTP_TIMEOUT=180
# 1 = live-запрос к API (тяжелее); 0 = в основном кэш прокси — мягче для Tourvisor
# YML_FEED_SYNC_LIVE=1
# Сколько направлений за один клик в админке (короткий запрос). 0 или all = все (долго, риск таймаута nginx)
# YML_FEED_ADMIN_MAX_COUNTRIES=15
# Гибрид: подпитка таблицы yandex_feed_offers при успешном акционном поиске на сайте (onlyPromo=1). 0 — только крон/кнопка в админке
# YML_FEED_INGEST_FROM_SEARCH=1
# Таблица yandex_feed_offers: полный синк Tourvisor, кнопка в админке, ingest из поиска, хвост promo_tours_refresh. 0 — только фид по правилам (/feed.yml, yandex_yml_feed_rules)
# YANDEX_LEGACY_OFFERS_TABLE_SYNC=1
# 1 + ?ymlDebug=1 на странице акций — в JSON ответа прокси добавляется _ymlIngest (цепочка ingest → БД), в консоли браузера видно шаги
# YML_CLIENT_DEBUG=0
# Сколько офферов максимум сохранить за один такой запрос поиска
# YML_FEED_HOOK_MAX_OFFERS=20
# --- YML по правилам (админка manage-yandex-feed.php, крон yml_feed_rules_cron.php → /feed.yml) ---
# Крон (ежедневно в 00:00 по времени сервера): 0 0 * * * cd /path/to/website-main && php backend/scripts/yml_feed_rules_cron.php >> data/yandex_yml_rules_cron.log 2>&1
# Таймаут HTTP на правило (сек), пауза между правилами (сек), 1 = live-поиск (тяжелее для API)
# YML_RULES_HTTP_TIMEOUT=120
# YML_RULES_RULE_DELAY_SEC=2
# YML_RULES_SEARCH_LIVE=0
# Публичный /feed.yml только читает снимок; пересборка — крон, GET cron-yml-feed.php или: php rebuild_feed.php
# TTL ниже не используется для авто-пересборки при GET (оставлено для совместимости со старыми .env).
# YML_RULES_FEED_TTL_SECONDS=600
# Порог перед заменой снимка (cron / rebuild_feed.php): мин. офферов и размер XML
# YML_RULES_MIN_OFFERS_FOR_PUBLISH=1
# YML_RULES_PUBLISH_MIN_XML_BYTES=1024
# Секрет для HTTP-крона пересборки /feed.yml (cron-job.org и т.п.):
# GET https://<ваш-домен>/backend/api/cron-yml-feed.php?key=<тот_же_секрет>
# Сгенерируйте длинную случайную строку (не коммитьте реальное значение).
# CRON_YML_SECRET=
# Отдельные фиды по городу вылета (Tourvisor departureId из правил → data/yandex_feed_dep_{id}.yml).
# Человекочитаемые копии и URL /feed-samara.yml, /feed-moscow.yml: slug:departureId через запятую (совпадает с .htaccess).
# Пример (подставьте свои ID из справочника Tourvisor): YML_FEED_DEPARTURE_ALIASES=samara:12,moscow:28
# YML_FEED_DEPARTURE_ALIASES=
# Переменные YANDEX_* ниже — для справки вместе с картами/виджетами; фид привязан к URL services_yml.php
# YANDEX_FEED_URL=/export/services_yml.php
# --- Флаги отката (prod): 0 / false / off — выключить поведение; пусто или 1 — включено ---
# Фильтр звёздности по правилам YML (админка → колонка hotel_stars_filter, сборка /feed.yml)
# TH_FEATURE_YML_RULE_HOTEL_STARS_FILTER=1
# Акции: только прямые перелёты для Таиланда (countryId 2) и Вьетнама (16/18)
# TH_FEATURE_PROMO_DIRECT_FLIGHTS_TH_VN=1
# Акции + promo_tours sync: Вьетнам (Tourvisor id 16/18) — если onlyPromo=1 пустой/без флага в JSON или ответ с ошибкой, подставить обычный поиск без onlyPromo (ближайшие даты)
# TH_FEATURE_PROMO_VIETNAM_NEAREST_FALLBACK=1

# ============ Mobile Sync API ============
# Обязательный Bearer токен для /backend/api/sync.php
# Сгенерируйте длинный случайный секрет (минимум 32 символа)
SYNC_API_TOKEN=
