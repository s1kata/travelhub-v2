RewriteEngine On

# Проброс Authorization в PHP (Apache/FastCGI)
RewriteCond %{HTTP:Authorization} .
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

RewriteRule ^submit-booking$ submit-booking.php [L,QSA]
RewriteRule ^bonus-balance$ bonus-balance.php [L,QSA]
RewriteRule ^bcard-activate$ bcard-activate.php [L,QSA]
RewriteRule ^bcard-bonus-create$ bcard-bonus-create.php [L,QSA]
RewriteRule ^client-bookings$ client-bookings.php [L,QSA]
RewriteRule ^reviews$ reviews.php [L,QSA]
RewriteRule ^review-helpful$ review-helpful.php [L,QSA]